
{

"version": 2,

"builds": [

{ "src": "backend/server.js", "use": "@vercel/node" },

{ "src": "frontend/index.html", "use": "@vercel/static" },

{ "src": "frontend/pricing.html", "use": "@vercel/static" },

{ "src": "frontend/services.html", "use": "@vercel/static" },

{ "src": "frontend/register.html", "use": "@vercel/static" }

],

"routes": [

{ "src": "/api/(.)", "dest": "backend/server.js" },

{ "src": "/pricing.html", "dest": "frontend/pricing.html" },

{ "src": "/pricing", "dest": "frontend/pricing.html" },

{ "src": "/services.html", "dest": "frontend/services.html" },

{ "src": "/services", "dest": "frontend/services.html" },

{ "src": "/register.html", "dest": "frontend/register.html" },

{ "src": "/register", "dest": "frontend/register.html" },

{ "src": "/(.)", "dest": "frontend/index.html" }

]

}

